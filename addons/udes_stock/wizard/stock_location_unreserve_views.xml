<?xml version="1.0"?>
<odoo>
    <data>

        <record id="stock_location_unreserve_form" model="ir.ui.view">
            <field name="name">stock.location.unreserve.form</field>
            <field name="model">stock.location.unreserve</field>
            <field name="arch" type="xml">
                <form string="Unreserve Form">
                    <notebook>
                        <page string="Affected Pickings">
                            <field name="affected_picking_ids" widget="many2many" nolabel="1">
                                <tree create="false">
                                    <field name="name"/>
                                    <field name="origin"/>
                                    <field name="location_id"/>
                                    <field name="date"/>
                                    <field name="scheduled_date"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Affected Move Lines">
                            <field name="affected_move_line_ids" widget="many2many" nolabel="1">
                                <tree create="false">
                                    <field name="picking_id"/>
                                    <field name="product_id"/>
                                    <field name="location_id"/>
                                    <field name="location_dest_id"/>
                                    <field name="package_id"/>
                                    <field name="result_package_id"/>
                                    <field name="lot_id"/>
                                    <field name="product_uom_qty"/>
                                    <field name="qty_done" optional="hide"/>
                                    <field name="product_uom_id"/>
                                    <field name="u_done_by_id" optional="show"/>
                                    <field name="u_done_datetime" optional="show"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Affected Moves">
                            <field name="affected_move_ids" widget="many2many" nolabel="1">
                                <tree create="false">
                                    <field name="picking_id"/>
                                    <field name="product_id"/>
                                    <field name="product_uom_qty"/>
                                    <field name="u_uom_initial_demand"/>
                                    <field name="quantity_done"/>
                                    <field name="product_uom"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                    <footer>
                        <button name="action_unreserve" type="object" string="Unreserve Stock" class="btn-primary"/>
                        <button special="cancel" string="Cancel" class="btn-default"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="stock_location_unreserve" model="ir.actions.act_window">
            <field name="name">Unreserve Stock</field>
            <field name="res_model">stock.location.unreserve</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
