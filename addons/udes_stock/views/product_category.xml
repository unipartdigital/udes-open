<?xml version="1.0"?>
<odoo>

    <record id="product_category_form_view" model="ir.ui.view">
        <field name="name">Product category form changes</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view" />
        <field name="arch" type="xml">
            <field name="parent_id" position="before">
                <field name="active" widget="boolean_toggle" />
            </field>
            <field name="parent_id" position="after">
                <field name="u_category_suggest_locations"/>
                <field name="u_suggest_locations"/>
            </field>
            <sheet position="inside">
                <notebook attrs="{'invisible': [('u_suggest_locations', '=', False)]}">
                    <page string="Suggested Locations" name="suggested_locations">
                        <separator string="Category Suggested Locations"/>
                        <field name="u_category_suggest_location_ids" widget="many2many_tags"/>
                        <separator string="Suggested Locations"/>
                        <field name="u_suggest_location_ids" widget="many2many_tags"/>
                    </page>
                </notebook>
            </sheet>
        </field>
    </record>

</odoo>
