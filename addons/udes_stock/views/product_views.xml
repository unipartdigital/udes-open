<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="product_product_view_form_easy_inherit_stock" model="ir.ui.view">
        <field name="name">product.product.view.form.easy.inherit.stock.udes_stock</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="stock.product_product_view_form_easy_inherit_stock"/>
        <field name="arch" type="xml">
            <!-- Hide update quantity on hand button for all users -->
            <xpath expr="//button[@name='action_update_quantity_on_hand']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="product_form_view_procurement_button" model="ir.ui.view">
        <field name="name">product.product.procurement.udes_stock</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="stock.product_form_view_procurement_button"/>
        <field name="arch" type="xml">
            <!-- Hide update quantity on hand button for all users -->
            <xpath expr="//button[@name='action_update_quantity_on_hand']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="product_template_form_view_procurement_button" model="ir.ui.view">
        <field name="name">product.template_procurement.udes_stock</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="stock.product_template_form_view_procurement_button"/>
        <field name="arch" type="xml">
            <!-- Hide update quantity on hand button for all users -->
            <xpath expr="//button[@name='action_update_quantity_on_hand']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="product_normal_form_view_udes_stock" model="ir.ui.view">
        <field name="name">product.product.form.udes_stock</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="attributes">
                <attribute name="attrs">{'invisible': [('u_multiple_barcodes', '=', True)]}</attribute>
            </xpath>
            <xpath expr="//field[@name='description']/parent::group" position="before">
                <group string="Barcodes" attrs="{'invisible':[('u_multiple_barcodes','=',False)]}">
                    <field name="u_barcode_ids" nolabel="1">
                        <tree string="Barcodes" editable="bottom">
                            <field name="name" required="1"/>
                        </tree>
                    </field>
                </group>
            </xpath>
        </field>
    </record>


</odoo>