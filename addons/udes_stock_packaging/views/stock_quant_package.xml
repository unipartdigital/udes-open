<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.ui.view" id="view_quant_package_form">
        <field name="name">udes_stock_packaging.stock.quant.package.form</field>
        <field name="inherit_id" ref="stock.view_quant_package_form"/>
        <field name="model">stock.quant.package</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='location_id']" position="after">
                <field name="u_container_type" />
                <field name="u_tracking_id" attrs="{'invisible': [('u_tracking_id', '=', False)]}"/>
            </xpath>
        </field>
    </record>

</odoo>
