<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.ui.view" id="view_quant_package_form">
        <field name="name">udes_stock_packaging.stock.quant.package.form</field>
        <field name="inherit_id" ref="stock.view_quant_package_form"/>
        <field name="model">stock.quant.package</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='location_id']" position="after">
                <field name="u_container_type" />
                <field name="u_tracking_id" attrs="{'invisible': [('u_tracking_id', '=', False)]}"/>
            </xpath>
            <xpath expr="//div[hasclass('oe_title')]" position="inside">
                <label for="u_package_type" string="Package Type" class="oe_edit_only"/>
                <h3><field name="u_package_type" class="oe_inline"/></h3>
            </xpath>
        </field>
    </record>

    <record model="ir.ui.view" id="quant_package_search_view_inherit">
        <field name="name">udes_stock_packaging.stock.quant.package.search</field>
        <field name="inherit_id" ref="stock.quant_package_search_view"/>
        <field name="model">stock.quant.package</field>
        <field name="arch" type="xml">
            <field name="packaging_id" position="after">
                <field name="u_package_type"/>
            </field>
            <filter name="packaging" position="after">
                <filter string="Package Type" name="package_type" domain="[]" context="{'group_by' : 'u_package_type'}"/>
            </filter>
        </field>
    </record>

    <record model="ir.ui.view" id="view_quant_package_tree_inherit">
        <field name="name">udes_stock_packaging.stock.quant.package.tree</field>
        <field name="inherit_id" ref="stock.view_quant_package_tree"/>
        <field name="model">stock.quant.package</field>
        <field name="arch" type="xml">
            <field name="location_id" position="after">
                <field name="u_package_type"/>
            </field>
        </field>
    </record>

    <record model="ir.ui.view" id="view_quant_package_kanban_inherit">
        <field name="name">udes_stock_packaging.stock.quant.package.kanban</field>
        <field name="inherit_id" ref="stock.view_quant_package_kanban"/>
        <field name="model">stock.quant.package</field>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_kanban_global_click')]" position="inside">
                <t t-if="record.u_package_type.value">
                    <div class="o_kanban_record_top mb0">
                        <strong><field name="u_package_type"/></strong>
                    </div>
                </t>
            </xpath>
        </field>
    </record>

</odoo>
