<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="container_type_action" model="ir.actions.act_window">
        <field name="name">Container Types</field>
        <field name="res_model">container.type</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="container_type_menu" name="Container Types"
        parent="stock.menu_product_in_config_stock"
        action="container_type_action" sequence="100" />

    <record id="container_type_form" model="ir.ui.view">
        <field name="name">container.type.form</field>
        <field name="model">container.type</field>
        <field name="arch" type="xml">
            <form string="Container Type" duplicate="0">
                <sheet>
                    <!-- Make name nice and large to edit -->
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" placeholder="e.g. Letter" />
                        </h1>
                    </div>
                    <group>
                        <field name="active" widget="boolean_toggle" />
                        <field name="use_product_dims" widget="boolean_toggle" />
                    </group>
                    <separator string="Physical Attributes" />
                    <group>
                        <group>
                            <field name="length" />
                            <field name="width" />
                            <field name="height" />
                        </group>
                        <group>
                            <field name="weight" />
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" />
                    <field name="message_ids" widget="mail_thread" />
                </div>
            </form>
        </field>
    </record>

    <record id="container_type_tree" model="ir.ui.view">
        <field name="name">container.type.tree</field>
        <field name="model">container.type</field>
        <field name="arch" type="xml">
            <tree string="Container Type">
                <field name="name" />
                <field name="length" />
                <field name="width" />
                <field name="height" />
                <field name="weight" />
            </tree>
        </field>
    </record>

    <record id="container_type_search" model="ir.ui.view">
        <field name="name">container.type.search</field>
        <field name="model">container.type</field>
        <field name="arch" type="xml">
            <search string="Search Container Types">
                <field name="name" />
                <filter name="filter_active" string="Active" domain="[('active','=', True)]" />
                <filter name="filter_inactive" string="Inactive" domain="[('active','=', False)]" />
            </search>
        </field>
    </record>
</odoo>
