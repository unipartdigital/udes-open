<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="package_type_action" model="ir.actions.act_window">
        <field name="name">Package Types</field>
        <field name="res_model">package.type</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="package_type_menu" name="Package Types"
        parent="stock.menu_product_in_config_stock"
        action="package_type_action" sequence="120" />

    <record id="package_type_form" model="ir.ui.view">
        <field name="name">package.type.form</field>
        <field name="model">package.type</field>
        <field name="arch" type="xml">
            <form string="Package Type">
                <sheet>
                    <!-- Make name nice and large to edit -->
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" placeholder="e.g. Pallet" />
                        </h1>
                    </div>
                    <group>
                        <field name="active" widget="boolean_toggle" />
                    </group>
                    <group>
                        <group>
                            <field name="sequence" />
                            <field name="sequence_id" options='{"no_open": True, "no_create": True}'/>
                        </group>
                        <group>
                            <field name="package_type_regex"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" />
                    <field name="message_ids" widget="mail_thread" />
                </div>
            </form>
        </field>
    </record>

    <record id="package_type_tree" model="ir.ui.view">
        <field name="name">package.type.tree</field>
        <field name="model">package.type</field>
        <field name="arch" type="xml">
            <tree string="Package Type">
                <field name="name" />
                <field name="package_type_regex" />
            </tree>
        </field>
    </record>

    <record id="package_type_search" model="ir.ui.view">
        <field name="name">package.type.search</field>
        <field name="model">package.type</field>
        <field name="arch" type="xml">
            <search string="Search Package Types">
                <field name="name" />
                <filter name="filter_active" string="Active" domain="[('active','=', True)]" />
                <filter name="filter_inactive" string="Inactive" domain="[('active','=', False)]" />
            </search>
        </field>
    </record>
</odoo>
